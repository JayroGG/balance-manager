{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": { "APP_ENV": "dev" }
    },
    "preview": {
      "distribution": "internal",
      "env": { "APP_ENV": "stage" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "APP_ENV": "prod" }
    }
  },
  "submit": {
    "production": {}
  }
}
