{
  "name": "balance-mobile",
  "version": "1.0.0",
  "description": "Expo React Native client for the balance personal-finance API (transactions, categories, savings vaults, and a computed balance).",
  "main": "expo-router/entry",
  "private": true,
  "license": "MIT",
  "author": "Jayro Gómez <jaxjayro@gmail.com> (https://github.com/JayroGG)",
  "homepage": "https://github.com/JayroGG/balance-manager#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JayroGG/balance-manager.git"
  },
  "bugs": {
    "url": "https://github.com/JayroGG/balance-manager/issues"
  },
  "keywords": [
    "expo",
    "react-native",
    "expo-router",
    "redux-toolkit",
    "rtk-query",
    "personal-finance",
    "budgeting"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "build:android": "scripts/build-android.sh",
    "build:android:apk": "scripts/build-android-apk.sh",
    "test": "jest",
    "coverage": "jest --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.[jt]sx?$",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@reduxjs/toolkit|react-redux|redux-persist|immer|reselect))"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-preset-expo": "~56.0.0",
    "dotenv": "^17.4.2",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "i18next": "^26.3.2",
    "luxon": "^3.7.2",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-redux": "^9.3.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "^19.2.3"
  }
}
