# Copy to .env.dev / .env.stage / .env.prod and fill in.
# Loaded by app.config.js via APP_ENV (e.g. `APP_ENV=dev npx expo start`).

# Backend base URL — host:port, NO /api prefix. Use your LAN IP (not localhost) for a physical device.
API_URL=http://192.168.1.100:3000

# Prototype auth: skip login and send a placeholder Bearer token (backend ignores it).
# Honored ONLY in dev — stage/prod require real email/password login. Set false there (ADR-011 guard).
AUTH_BYPASS=true

# Echoed into expo extra for display/debug.
APP_ENV=dev
