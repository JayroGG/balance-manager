/.claude/*
!/.claude/ADR/
!/.claude/agents/
/.claude/agents/*
!/.claude/agents/plans/
.qodo/

# jest coverage output
/coverage

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
